<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!--
            CRON: Verify whitelist consistency
            Daily. Flags active wallets that have an address but are not
            whitelisted on-chain. Creates audit log warnings.
        -->
        <record id="ir_cron_verify_whitelist" model="ir.cron">
            <field name="name">Solar Wallet: Verify whitelist consistency</field>
            <field name="model_id" ref="solar_wallet.model_solar_wallet"/>
            <field name="state">code</field>
            <field name="code">model._cron_verify_whitelist_consistency()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="numbercall">-1</field>
            <field name="active">True</field>
            <field name="user_id" ref="base.user_root"/>
        </record>

    </data>
</odoo>

<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============================================================ -->
    <!-- KANBAN — vue opérationnelle pour l'asset manager             -->
    <!-- ============================================================ -->
    <record id="view_solar_asset_kanban" model="ir.ui.view">
        <field name="name">solar.asset.kanban</field>
        <field name="model">solar.asset</field>
        <field name="arch" type="xml">
            <kanban string="Solar Assets"
                    default_group_by="state"
                    group_create="false"
                    group_delete="false">
                <field name="state"/>
                <field name="code"/>
                <field name="name"/>
                <field name="country_id"/>
                <field name="asset_type"/>
                <field name="target_yield_rate"/>
                <field name="cells_available"/>
                <field name="total_cells"/>
                <field name="cells_subscribed"/>
                <templates>
                    <t t-name="kanban-box">
                        <div class="oe_kanban_global_click o_kanban_record">
                            <div class="o_kanban_record_top">
                                <div class="o_kanban_record_headings">
                                    <strong class="o_kanban_record_title">
                                        <field name="name"/>
                                    </strong>
                                    <span class="o_kanban_record_subtitle text-muted">
                                        <field name="code"/>
                                    </span>
                                </div>
                                <field name="state" widget="label_selection"
                                       options="{'classes': {
                                           'in_production': 'success',
                                           'financing': 'warning',
                                           'financing_complete': 'info',
                                           'pending_approval': 'secondary',
                                           'draft': 'secondary',
                                           'paused': 'warning',
                                           'mature': 'info',
                                           'decommissioned': 'muted',
                                           'cancelled': 'danger'
                                       }}"/>
                            </div>
                            <div class="o_kanban_record_body">
                                <div class="text-muted">
                                    <field name="country_id"/> ·
                                    <field name="asset_type"/>
                                </div>
                                <div class="mt-1">
                                    Yield: <strong><field name="target_yield_rate" widget="percentage"/></strong>
                                </div>
                                <div class="mt-1">
                                    Cells: <field name="cells_subscribed"/>/<field name="total_cells"/>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- ============================================================ -->
    <!-- LIST                                                           -->
    <!-- ============================================================ -->
    <record id="view_solar_asset_tree" model="ir.ui.view">
        <field name="name">solar.asset.tree</field>
        <field name="model">solar.asset</field>
        <field name="arch" type="xml">
            <tree string="Solar Assets"
                  decoration-success="state == 'in_production'"
                  decoration-warning="state in ['financing', 'pending_approval', 'paused']"
                  decoration-info="state in ['financing_complete', 'mature']"
                  decoration-muted="state in ['decommissioned', 'cancelled', 'draft']">
                <field name="code"/>
                <field name="name"/>
                <field name="country_id"/>
                <field name="asset_type"/>
                <field name="installed_power_mwc" optional="show"/>
                <field name="target_yield_rate" widget="percentage"/>
                <field name="cell_unit_price" optional="hide"/>
                <field name="cells_subscribed" optional="show"/>
                <field name="total_cells" optional="show"/>
                <field name="cells_available" optional="show"/>
                <field name="distribution_frequency" optional="hide"/>
                <field name="state" widget="badge"/>
                <field name="commissioning_date" optional="hide"/>
            </tree>
        </field>
    </record>

    <!-- ============================================================ -->
    <!-- FORM                                                           -->
    <!-- ============================================================ -->
    <record id="view_solar_asset_form" model="ir.ui.view">
        <field name="name">solar.asset.form</field>
        <field name="model">solar.asset</field>
        <field name="arch" type="xml">
            <form string="Solar Asset">
                <header>
                    <button name="action_request_approval"
                            string="Request approval"
                            type="object"
                            states="draft"
                            class="oe_highlight"
                            groups="solar_core.group_asset_manager"/>

                    <button name="action_approve"
                            string="Approve &amp; open financing"
                            type="object"
                            states="pending_approval"
                            class="oe_highlight"
                            groups="solar_core.group_compliance"
                            confirm="Approve this asset? It will open for investor subscriptions."/>

                    <button name="action_commission"
                            string="Commission (go live)"
                            type="object"
                            states="financing_complete"
                            class="oe_highlight"
                            groups="solar_core.group_asset_manager,solar_core.group_compliance"/>

                    <button name="action_pause"
                            string="Pause"
                            type="object"
                            states="in_production"
                            groups="solar_core.group_compliance"/>

                    <button name="action_resume"
                            string="Resume"
                            type="object"
                            states="paused"
                            class="oe_highlight"
                            groups="solar_core.group_compliance"/>

                    <button name="action_decommission"
                            string="Decommission"
                            type="object"
                            states="mature,in_production"
                            class="btn-danger"
                            groups="solar_core.group_compliance"
                            confirm="Decommission this asset? This action is final."/>

                    <button name="action_cancel"
                            string="Cancel"
                            type="object"
                            states="pending_approval,financing"
                            class="btn-danger"
                            groups="solar_core.group_compliance"
                            confirm="Cancel this asset? Investor refunds will be triggered."/>

                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,pending_approval,financing,financing_complete,in_production,mature,decommissioned"/>
                </header>

                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_documents" type="object"
                                class="oe_stat_button" icon="fa-file">
                            <field name="document_count" widget="statinfo" string="Docs"/>
                        </button>
                    </div>

                    <group>
                        <group string="Identity">
                            <field name="code"/>
                            <field name="name"/>
                            <field name="slug"/>
                            <field name="uuid" readonly="1" groups="base.group_no_one"/>
                        </group>
                        <group string="Classification">
                            <field name="asset_type"/>
                            <field name="distribution_frequency"/>
                            <field name="is_secondary_market_enabled" widget="boolean_toggle"/>
                        </group>
                    </group>

                    <notebook>
                        <page string="Geography">
                            <group>
                                <group>
                                    <field name="country_id"/>
                                    <field name="region"/>
                                    <field name="city"/>
                                </group>
                                <group>
                                    <field name="latitude"/>
                                    <field name="longitude"/>
                                </group>
                            </group>
                        </page>

                        <page string="Technical specs">
                            <group>
                                <group>
                                    <field name="installed_power_mwc"/>
                                    <field name="annual_production_mwh"/>
                                    <field name="commissioning_date"/>
                                </group>
                                <group>
                                    <field name="project_duration_years"/>
                                    <field name="project_end_date" readonly="1"/>
                                </group>
                            </group>
                        </page>

                        <page string="Financials">
                            <group>
                                <group string="Capital structure">
                                    <field name="currency_id"/>
                                    <field name="cell_unit_price"/>
                                    <field name="total_cells"/>
                                    <field name="total_capital_raised"/>
                                    <field name="target_yield_rate" widget="percentage"/>
                                </group>
                                <group string="Subscription progress">
                                    <field name="cells_subscribed"/>
                                    <field name="cells_available"/>
                                </group>
                            </group>
                        </page>

                        <page string="PPA">
                            <group>
                                <field name="ppa_type"/>
                                <field name="ppa_price_per_kwh"/>
                                <field name="ppa_duration_years"/>
                                <field name="ppa_buyer_id"/>
                            </group>
                        </page>

                        <page string="Operations">
                            <group>
                                <field name="operator_id"/>
                                <field name="owner_spv_id"/>
                                <field name="insurance_provider"/>
                                <field name="insurance_policy_ref"/>
                            </group>
                            <group string="Geo restrictions">
                                <field name="geo_restriction_country_ids" widget="many2many_tags"/>
                            </group>
                        </page>

                        <page string="On-chain">
                            <group>
                                <field name="on_chain_token_address"/>
                                <field name="on_chain_token_symbol"/>
                                <field name="on_chain_deployed_at" readonly="1"/>
                            </group>
                        </page>

                        <page string="Documents">
                            <field name="document_ids">
                                <tree editable="bottom">
                                    <field name="document_type"/>
                                    <field name="label" optional="show"/>
                                    <field name="is_public"/>
                                    <field name="mime_type" optional="hide"/>
                                    <field name="file_size_bytes" optional="hide"/>
                                    <field name="uploaded_at"/>
                                </tree>
                            </field>
                        </page>

                        <page string="Content">
                            <field name="description"/>
                            <field name="image_url"/>
                        </page>
                    </notebook>
                </sheet>

                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <!-- ============================================================ -->
    <!-- SEARCH                                                         -->
    <!-- ============================================================ -->
    <record id="view_solar_asset_search" model="ir.ui.view">
        <field name="name">solar.asset.search</field>
        <field name="model">solar.asset</field>
        <field name="arch" type="xml">
            <search string="Search assets">
                <field name="code"/>
                <field name="name"/>
                <field name="slug"/>

                <separator/>
                <filter string="Draft"              name="draft"              domain="[('state','=','draft')]"/>
                <filter string="Pending approval"   name="pending_approval"   domain="[('state','=','pending_approval')]"/>
                <filter string="Financing"          name="financing"          domain="[('state','=','financing')]"/>
                <filter string="In production"      name="in_production"      domain="[('state','=','in_production')]"/>
                <filter string="Paused"             name="paused"             domain="[('state','=','paused')]"/>
                <filter string="Mature"             name="mature"             domain="[('state','=','mature')]"/>

                <separator/>
                <filter string="Secondary market ON"
                        name="secondary_market"
                        domain="[('is_secondary_market_enabled','=',True)]"/>
                <filter string="Fully subscribed"
                        name="fully_subscribed"
                        domain="[('cells_available','=',0),('total_cells','>',0)]"/>

                <group string="Group by">
                    <filter string="State"     name="group_state"     context="{'group_by':'state'}"/>
                    <filter string="Type"      name="group_type"      context="{'group_by':'asset_type'}"/>
                    <filter string="Country"   name="group_country"   context="{'group_by':'country_id'}"/>
                    <filter string="Frequency" name="group_frequency" context="{'group_by':'distribution_frequency'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- ============================================================ -->
    <!-- ACTIONS                                                        -->
    <!-- ============================================================ -->
    <record id="action_solar_asset_all" model="ir.actions.act_window">
        <field name="name">All Assets</field>
        <field name="res_model">solar.asset</field>
        <field name="view_mode">kanban,tree,form</field>
        <field name="search_view_id" ref="view_solar_asset_search"/>
    </record>

    <record id="action_solar_asset_financing" model="ir.actions.act_window">
        <field name="name">Assets in financing</field>
        <field name="res_model">solar.asset</field>
        <field name="view_mode">kanban,tree,form</field>
        <field name="domain">[('state','in',['financing','financing_complete'])]</field>
    </record>

    <record id="action_solar_asset_in_production" model="ir.actions.act_window">
        <field name="name">Assets in production</field>
        <field name="res_model">solar.asset</field>
        <field name="view_mode">tree,kanban,form</field>
        <field name="domain">[('state','=','in_production')]</field>
    </record>

    <!-- ir.rule: investors only see public states -->
    <record id="rule_asset_investor_visibility" model="ir.rule">
        <field name="name">Investors see only public assets</field>
        <field name="model_id" ref="solar_asset.model_solar_asset"/>
        <field name="groups" eval="[(4, ref('solar_core.group_investor'))]"/>
        <field name="domain_force">[('state', 'in', ['financing', 'financing_complete', 'in_production', 'mature'])]</field>
        <field name="perm_read" eval="1"/>
        <field name="perm_write" eval="0"/>
        <field name="perm_create" eval="0"/>
        <field name="perm_unlink" eval="0"/>
    </record>

</odoo>

<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!--
            CRON: Expire KYC cases
            Runs daily. Transitions validated cases past their expires_at
            date to the 'expired' state and creates renewal_required decisions.
        -->
        <record id="ir_cron_expire_kyc" model="ir.cron">
            <field name="name">Solar KYC: Expire overdue cases</field>
            <field name="model_id" ref="solar_kyc.model_solar_kyc_case"/>
            <field name="state">code</field>
            <field name="code">model._cron_expire_kyc_cases()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="numbercall">-1</field>
            <field name="active">True</field>
            <field name="user_id" ref="base.user_root"/>
        </record>

        <!--
            CRON: Remind investors about expiring KYC
            Runs weekly. Logs reminder entries for cases expiring within 30 days.
            The Node.js backend consumes these audit events and sends e-mails.
        -->
        <record id="ir_cron_remind_expiring_kyc" model="ir.cron">
            <field name="name">Solar KYC: Remind expiring cases (30d)</field>
            <field name="model_id" ref="solar_kyc.model_solar_kyc_case"/>
            <field name="state">code</field>
            <field name="code">model._cron_remind_expiring_kyc()</field>
            <field name="interval_number">7</field>
            <field name="interval_type">days</field>
            <field name="numbercall">-1</field>
            <field name="active">True</field>
            <field name="user_id" ref="base.user_root"/>
        </record>

    </data>
</odoo>

<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============================================================ -->
    <!-- KANBAN — principal outil de travail des KYC operators        -->
    <!-- ============================================================ -->
    <record id="view_solar_kyc_case_kanban" model="ir.ui.view">
        <field name="name">solar.kyc.case.kanban</field>
        <field name="model">solar.kyc.case</field>
        <field name="arch" type="xml">
            <kanban string="KYC Cases"
                    default_group_by="state"
                    group_create="false"
                    group_delete="false">
                <field name="state"/>
                <field name="partner_id"/>
                <field name="level"/>
                <field name="expires_at"/>
                <field name="document_count"/>
                <field name="decision_count"/>
                <templates>
                    <t t-name="kanban-box">
                        <div class="oe_kanban_global_click o_kanban_record">
                            <div class="o_kanban_record_top">
                                <div class="o_kanban_record_headings">
                                    <strong class="o_kanban_record_title">
                                        <field name="partner_id"/>
                                    </strong>
                                    <span class="o_kanban_record_subtitle text-muted">
                                        <field name="name"/>
                                    </span>
                                </div>
                                <field name="state" widget="label_selection"
                                       options="{'classes': {
                                           'validated': 'success',
                                           'rejected': 'danger',
                                           'submitted': 'info',
                                           'under_review': 'warning',
                                           'expired': 'warning',
                                           'suspended': 'danger',
                                           'in_progress': 'secondary',
                                           'not_started': 'secondary'
                                       }}"/>
                            </div>
                            <div class="o_kanban_record_body">
                                <div class="text-muted">
                                    Level: <field name="level"/>
                                </div>
                                <div class="text-muted">
                                    Docs: <field name="document_count"/>
                                    · Decisions: <field name="decision_count"/>
                                </div>
                                <t t-if="record.expires_at.raw_value">
                                    <div class="text-muted">
                                        Expires: <field name="expires_at"/>
                                    </div>
                                </t>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- ============================================================ -->
    <!-- LIST                                                           -->
    <!-- ============================================================ -->
    <record id="view_solar_kyc_case_tree" model="ir.ui.view">
        <field name="name">solar.kyc.case.tree</field>
        <field name="model">solar.kyc.case</field>
        <field name="arch" type="xml">
            <tree string="KYC Cases"
                  decoration-success="state == 'validated'"
                  decoration-warning="state in ['submitted', 'under_review', 'expired']"
                  decoration-danger="state in ['rejected', 'suspended']"
                  decoration-muted="state == 'not_started'">
                <field name="name"/>
                <field name="partner_id"/>
                <field name="state" widget="badge"/>
                <field name="level"/>
                <field name="provider"/>
                <field name="document_count" string="Docs"/>
                <field name="submitted_at" optional="show"/>
                <field name="validated_at" optional="show"/>
                <field name="expires_at"   optional="show"/>
                <field name="risk_score"   optional="hide"/>
                <field name="pep_status"   optional="hide" widget="boolean"/>
            </tree>
        </field>
    </record>

    <!-- ============================================================ -->
    <!-- FORM                                                           -->
    <!-- ============================================================ -->
    <record id="view_solar_kyc_case_form" model="ir.ui.view">
        <field name="name">solar.kyc.case.form</field>
        <field name="model">solar.kyc.case</field>
        <field name="arch" type="xml">
            <form string="KYC Case">
                <header>
                    <!-- Actions by state -->
                    <button name="action_submit"
                            string="Submit for review"
                            states="in_progress"
                            type="object"
                            class="oe_highlight"
                            groups="solar_core.group_api,solar_kyc.group_kyc_operator"/>

                    <button name="action_escalate"
                            string="Escalate — manual review"
                            states="submitted"
                            type="object"
                            groups="solar_kyc.group_kyc_operator,solar_core.group_compliance"/>

                    <button name="action_approve"
                            string="Approve"
                            states="submitted,under_review"
                            type="object"
                            class="oe_highlight"
                            groups="solar_core.group_compliance"
                            context="{'default_kyc_level': 'L2'}"
                            confirm="Approve this KYC case? A decision record will be created."/>

                    <button name="action_reject"
                            string="Reject"
                            states="submitted,under_review"
                            type="object"
                            class="btn-danger"
                            groups="solar_core.group_compliance"
                            confirm="Reject this KYC case? This action cannot be undone."/>

                    <button name="action_renew"
                            string="Start renewal"
                            states="expired,rejected"
                            type="object"
                            groups="solar_core.group_compliance"/>

                    <button name="action_suspend"
                            string="Suspend"
                            states="validated"
                            type="object"
                            class="btn-warning"
                            groups="solar_core.group_compliance"/>

                    <field name="state" widget="statusbar"
                           statusbar_visible="not_started,in_progress,submitted,validated"/>
                </header>

                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_documents" type="object"
                                class="oe_stat_button" icon="fa-file">
                            <field name="document_count" widget="statinfo" string="Docs"/>
                        </button>
                        <button name="action_view_decisions" type="object"
                                class="oe_stat_button" icon="fa-gavel">
                            <field name="decision_count" widget="statinfo" string="Decisions"/>
                        </button>
                    </div>

                    <group>
                        <group string="Investor">
                            <field name="name" readonly="1"/>
                            <field name="partner_id"/>
                            <field name="uuid" readonly="1" groups="base.group_no_one"/>
                        </group>
                        <group string="KYC status">
                            <field name="level"/>
                            <field name="provider"/>
                            <field name="provider_case_id"/>
                            <field name="risk_score"/>
                            <field name="pep_status" widget="boolean_toggle"/>
                        </group>
                    </group>

                    <group>
                        <group string="Timeline">
                            <field name="submitted_at" readonly="1"/>
                            <field name="validated_at" readonly="1"/>
                            <field name="expires_at"   readonly="1"/>
                            <field name="rejected_at"  readonly="1"
                                   invisible="not rejected_at"/>
                        </group>
                        <group string="Rejection" invisible="state not in ['rejected','suspended']">
                            <field name="rejection_reason" readonly="1"/>
                        </group>
                    </group>

                    <notebook>
                        <page string="Documents">
                            <field name="document_ids">
                                <tree editable="bottom" create="false" delete="false">
                                    <field name="document_type"/>
                                    <field name="state" widget="badge"/>
                                    <field name="mime_type"/>
                                    <field name="file_size_bytes"/>
                                    <field name="uploaded_at"/>
                                    <field name="reviewed_at" optional="show"/>
                                    <field name="reviewed_by" optional="show"/>
                                </tree>
                            </field>
                        </page>
                        <page string="Decisions (immutable)">
                            <field name="decision_ids" readonly="1">
                                <tree create="false" edit="false" delete="false">
                                    <field name="decision_at"/>
                                    <field name="decision" widget="badge"/>
                                    <field name="kyc_level"/>
                                    <field name="decision_source"/>
                                    <field name="decided_by"/>
                                    <field name="previous_state"/>
                                    <field name="new_state"/>
                                </tree>
                            </field>
                        </page>
                        <page string="Risk &amp; PEP" groups="solar_core.group_compliance">
                            <group>
                                <field name="pep_status"/>
                                <field name="pep_details" invisible="not pep_status"/>
                                <field name="sanctions_check_at"/>
                                <field name="risk_score"/>
                            </group>
                        </page>
                    </notebook>
                </sheet>

                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <!-- ============================================================ -->
    <!-- SEARCH                                                         -->
    <!-- ============================================================ -->
    <record id="view_solar_kyc_case_search" model="ir.ui.view">
        <field name="name">solar.kyc.case.search</field>
        <field name="model">solar.kyc.case</field>
        <field name="arch" type="xml">
            <search string="Search KYC cases">
                <field name="name"/>
                <field name="partner_id"/>
                <field name="provider_case_id"/>

                <separator/>
                <filter string="Not started"   name="not_started"  domain="[('state','=','not_started')]"/>
                <filter string="In progress"   name="in_progress"  domain="[('state','=','in_progress')]"/>
                <filter string="Submitted"     name="submitted"    domain="[('state','=','submitted')]"/>
                <filter string="Under review"  name="under_review" domain="[('state','=','under_review')]"/>
                <filter string="Validated"     name="validated"    domain="[('state','=','validated')]"/>
                <filter string="Rejected"      name="rejected"     domain="[('state','=','rejected')]"/>
                <filter string="Expired"       name="expired"      domain="[('state','=','expired')]"/>
                <filter string="Suspended"     name="suspended"    domain="[('state','=','suspended')]"/>

                <separator/>
                <filter string="PEP" name="pep" domain="[('pep_status','=',True)]"/>
                <filter string="Expiring in 30 days" name="expiring_soon"
                        domain="[('state','=','validated'),
                                 ('expires_at','&lt;=',(datetime.datetime.now() + datetime.timedelta(days=30)).strftime('%Y-%m-%d %H:%M:%S'))]"/>

                <group string="Group by">
                    <filter string="State"    name="group_state"    context="{'group_by':'state'}"/>
                    <filter string="Level"    name="group_level"    context="{'group_by':'level'}"/>
                    <filter string="Provider" name="group_provider" context="{'group_by':'provider'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- ============================================================ -->
    <!-- WINDOW ACTIONS                                                 -->
    <!-- ============================================================ -->
    <record id="action_solar_kyc_cases" model="ir.actions.act_window">
        <field name="name">All KYC Cases</field>
        <field name="res_model">solar.kyc.case</field>
        <field name="view_mode">kanban,tree,form</field>
        <field name="search_view_id" ref="view_solar_kyc_case_search"/>
    </record>

    <record id="action_solar_kyc_pending" model="ir.actions.act_window">
        <field name="name">Pending review</field>
        <field name="res_model">solar.kyc.case</field>
        <field name="view_mode">kanban,tree,form</field>
        <field name="domain">[('state','in',['submitted','under_review'])]</field>
        <field name="context">{'search_default_submitted': 1, 'search_default_under_review': 1}</field>
    </record>

    <record id="action_solar_kyc_expiring" model="ir.actions.act_window">
        <field name="name">Expiring soon (30d)</field>
        <field name="res_model">solar.kyc.case</field>
        <field name="view_mode">tree,form</field>
        <field name="domain">[('state','=','validated')]</field>
        <field name="context">{'search_default_expiring_soon': 1}</field>
    </record>

</odoo>

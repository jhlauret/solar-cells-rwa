# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_DB=solarcells
POSTGRES_USER=odoo
POSTGRES_PASSWORD=odoo_secure_password

# ── Odoo API ──────────────────────────────────────────────────────────────────
ODOO_API_USER=api@solarcells.com
ODOO_API_PASSWORD=api_secure_password

# ── MinIO ─────────────────────────────────────────────────────────────────────
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin_secure

# ── JWT (min 32 caractères chacun) ───────────────────────────────────────────
JWT_ACCESS_SECRET=change-me-in-production-access-secret-min-32-chars
JWT_REFRESH_SECRET=change-me-in-production-refresh-secret-min-32-chars

# ── Stripe ────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ── SMTP (emails OTP) ─────────────────────────────────────────────────────────
# Mailgun : smtp.mailgun.org:587
# SendGrid : smtp.sendgrid.net:587
# Gmail    : smtp.gmail.com:587
SMTP_HOST=smtp.mailgun.org
SMTP_PORT=587
SMTP_USER=postmaster@mg.solarcells.com
SMTP_PASSWORD=smtp_password_here
SMTP_FROM_EMAIL=noreply@solarcells.com

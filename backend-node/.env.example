# ─── Application ─────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001
API_PREFIX=/api/v1

# ─── JWT ─────────────────────────────────────────────────────────────────────
JWT_ACCESS_SECRET=change-me-in-production-access-secret-min-32-chars
JWT_REFRESH_SECRET=change-me-in-production-refresh-secret-min-32-chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── Odoo ─────────────────────────────────────────────────────────────────────
ODOO_URL=http://odoo:8069
ODOO_DB=solarcells
ODOO_API_USER=api@solarcells.com
ODOO_API_PASSWORD=api_password_here
# Alternatively use API key (Odoo 17+):
# ODOO_API_KEY=your_odoo_api_key_here

# ─── MinIO ───────────────────────────────────────────────────────────────────
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_KYC=kyc-documents
MINIO_BUCKET_ASSETS=asset-documents

# ─── Stripe ──────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ─── Bridge (Stripe stablecoin) ──────────────────────────────────────────────
BRIDGE_API_KEY=bridge_api_key_here
BRIDGE_WEBHOOK_SECRET=bridge_webhook_secret_here

# ─── CORS ─────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:5173,https://app.solarcells.com

# ─── Rate limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
